# ===== Mirrorverse root environment =====
# Copy to .env and fill in real values.

# Anthropic Claude API (backend LLM calls + MiroFish LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Neo4j Aura (free tier) — decision graph storage
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Mem0 — user memory / behavioral patterns
MEM0_API_KEY=your_mem0_api_key_here

# Zep — MiroFish agent memory (free tier: https://app.getzep.com/)
ZEP_API_KEY=your_zep_api_key_here

# MiroFish microservice (backend API port)
MIROFISH_URL=http://localhost:5001

# Google Cloud
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
